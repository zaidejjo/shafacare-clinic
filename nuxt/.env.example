# ========================================================
# Shafa Care Clinic – Environment Variables (Example)
# ========================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Storyblok Headless CMS ─────────────────────────────
# 1. Go to your Storyblok space: Settings > Access Tokens
# 2. Create or copy the "Preview" token for development
# 3. Create or copy the "Public" token for production
STORYBLOK_ACCESS_TOKEN=

# ── Site URL ───────────────────────────────────────────
# The public URL of your website (no trailing slash).
# Used for canonical URLs, sitemap, and Open Graph tags.
NUXT_PUBLIC_SITE_URL=https://shafacare.pages.dev
